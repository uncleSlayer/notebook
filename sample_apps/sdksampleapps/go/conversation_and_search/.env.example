# PipesHub backend (defaults assume a local dev backend)
PIPESHUB_BASE_URL=http://localhost:3000/api/v1

# Auth credentials
PIPESHUB_EMAIL=you@example.com
PIPESHUB_PASSWORD=your-password

# Demo query used by every scenario
PIPESHUB_QUERY=what does this knowledge base contain?

# Agent key — required for the agent conversation scenarios.
# Get one from the PipesHub UI under Agents → API Key.
AGENT_KEY=

# Knowledge base ID — optional. Set this to enable the KB-filtered scenarios
# (filtered conversation + filtered semantic search). Leave empty to skip.
PIPESHUB_KB_ID=
